      "name": "On form submission",
      "webhookId": "19f3819c-f4de-4448-b0ef-7044f135fb49"
    },
    {
      "parameters": {
        "jsCode": "const shopId = $('On form submission').first().json.shop_id;\nconst raw = $('On form submission').first().json.content;\n\nreturn raw\n  .split(/\\n\\s*\\n/)\n  .map(c => c.trim())\n  .filter(Boolean)\n  .map(content => ({ json: { shop_id: shopId, content } }));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        208,
        0
      ],
      "id": "72217f59-3165-4d5a-b991-bda0c9816db0",
      "name": "Split Chunks"
    },
    {
      "parameters": {
        "jsCode": "function normalizePersian(text) {\n  if (!text) return '';\n  return text\n    .replace(/ي/g, 'ی').replace(/ك/g, 'ک')\n    .replace(/[٠-٩]/g, d => '٠١٢٣٤٥٦٧٨٩'.indexOf(d))\n    .replace(/[۰-۹]/g, d => '۰۱۲۳۴۵۶۷۸۹'.indexOf(d))\n    .replace(/\\u200c/g, ' ')\n    .replace(/\\s+/g, ' ').trim();\n}\n\nfor (const item of $input.all()) {\n  item.json.normalized = normalizePersian(item.json.content);\n}\nreturn $input.all();"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        416,
        0
      ],
      "id": "e938cf03-1f87-49d1-9ba0-726d79753418",
      "name": "Normalize"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://generativelanguage.googleapis.com/v1beta/models/gemini-embedding-001:embedContent?key=<GEMINI_API_KEY>",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"models/gemini-embedding-001\",\n  \"content\": {\n    \"parts\": [\n      { \"text\": \"={{ $json.normalized }}\" }\n    ]\n  }\n}",
        "options": {
          "batching": {
            "batch": {
              "batchSize": 1
            }
          }
        }
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        624,
