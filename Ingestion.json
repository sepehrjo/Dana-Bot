    {
      "parameters": {
        "jsCode": "const shopId = $('Split Chunks').item.json.shop_id;\nconst content = $('Split Chunks').item.json.content;\nconst embedding = $('Gemini Embed').item.json.embedding.values;\n\nreturn [{\n  json: {\n    shop_id: shopId,\n    content: content,\n    embedding: embedding\n  }\n}];"
      },
